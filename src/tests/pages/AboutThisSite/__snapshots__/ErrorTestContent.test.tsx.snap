            />
          </svg>
        </div>
      </div>
      <div
        class="flex justify-center gap-4 mb-6"
      >
        <button
          class="btn btn-sm btn-outline"
        >
          Test
        </button>
        <button
          class="btn btn-sm btn-outline btn-accent btn-disabled"
